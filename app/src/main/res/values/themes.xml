<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Shared splash attrs (pre-API 31 uses this directly; API 31+ extends in values-v31). -->
    <style name="Theme.Nestore.Splash.Base" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/brand_primary_dark</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:navigationBarColor">@color/brand_primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.Nestore.Splash" parent="Theme.Nestore.Splash.Base" />

    <style name="Theme.Nestore_15" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary_dark</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="colorAccent">@color/brand_orange</item>
        <item name="android:colorBackground">@color/ghost_white</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:navigationBarColor">@color/ghost_white</item>

        <item name="android:windowBackground">@color/ghost_white</item>

        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:textColorPrimary">@color/midnight_navy</item>
        <item name="android:textColorSecondary">@color/deep_royal_text</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>
</resources>