<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#E8EEF7"
                android:startColor="#D4DEEA" />
        </shape>
    </item>
    <item
        android:bottom="24dp"
        android:left="24dp"
        android:right="24dp"
        android:top="24dp">
        <bitmap
            android:gravity="center"
            android:src="@drawable/apartment_complex"
            android:alpha="140" />
    </item>
</layer-list>
