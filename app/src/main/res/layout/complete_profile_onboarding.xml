<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ghost_white"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/onboardingToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:navigationIcon="@drawable/ic_back_arrow" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step 2 of 2 · Your profile"
                android:textColor="@color/deep_royal_text"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tell us a bit more"
                android:textColor="@color/midnight_navy"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Everything below is optional now. You can complete or update these anytime from Profile."
                android:textColor="@color/deep_royal_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvOnboardingRoleIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/midnight_navy"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/onboardingStudentBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Institution / university (optional)"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="12sp" />

                <AutoCompleteTextView
                    android:id="@+id/etOnboardStudentInstitution"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/input_glass_bg"
                    android:hint="e.g. University of Botswana"
                    android:inputType="textCapWords"
                    android:minHeight="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Student ID (optional)"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etOnboardStudentId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Student ID number"
                    android:minHeight="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Preferred area (optional)"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etOnboardStudentLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Gaborone, Phase 2"
                    android:minHeight="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Budget max BWP/month (optional)"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etOnboardStudentBudget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 2500"
                    android:inputType="numberDecimal"
                    android:minHeight="48dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOnboardPickEnrollment"
                    style="@style/Widget.Nestore.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Upload proof of enrollment (optional)"
                    android:textAllCaps="false" />

                <TextView
                    android:id="@+id/tvOnboardEnrollmentStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/onboardingProviderBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Business or owner name (optional)"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etOnboardProviderBusiness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Displayed to students"
                    android:minHeight="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Contact address (optional)"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etOnboardProviderAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Physical or mailing address"
                    android:minHeight="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Properties you manage (optional)"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etOnboardProviderCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Approximate count"
                    android:inputType="number"
                    android:minHeight="48dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOnboardPickOwnership"
                    style="@style/Widget.Nestore.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Upload ownership proof (optional)"
                    android:textAllCaps="false" />

                <TextView
                    android:id="@+id/tvOnboardOwnershipStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/deep_royal_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/pbOnboarding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOnboardingSave"
                style="@style/Widget.Nestore.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Save and continue"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOnboardingSkip"
                style="@style/Widget.Nestore.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp"
                android:text="Skip for now"
                android:textAllCaps="false" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
