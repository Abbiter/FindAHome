<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ghost_white"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/secondaryToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:navigationIcon="@drawable/ic_back_arrow" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvPropertyFormHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/midnight_navy"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPropertyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Title"
                android:inputType="textCapSentences"
                android:minHeight="48dp"
                android:textColor="@color/midnight_navy"
                android:textColorHint="@color/deep_royal_text" />

            <EditText
                android:id="@+id/etPropertyDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="top"
                android:hint="Description"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="4"
                android:textColor="@color/midnight_navy"
                android:textColorHint="@color/deep_royal_text" />

            <EditText
                android:id="@+id/etPropertyLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Location"
                android:inputType="textCapWords"
                android:minHeight="48dp"
                android:textColor="@color/midnight_navy"
                android:textColorHint="@color/deep_royal_text" />

            <EditText
                android:id="@+id/etPropertyPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Price (BWP / month)"
                android:inputType="numberDecimal"
                android:minHeight="48dp"
                android:textColor="@color/midnight_navy"
                android:textColorHint="@color/deep_royal_text" />

            <EditText
                android:id="@+id/etPropertyRooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Number of rooms"
                android:inputType="number"
                android:minHeight="48dp"
                android:textColor="@color/midnight_navy"
                android:textColorHint="@color/deep_royal_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Availability status"
                android:textColor="@color/deep_royal_text"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spPropertyStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/etPropertyAvailabilityDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Available from (yyyy-MM-dd)"
                android:inputType="date"
                android:minHeight="48dp"
                android:textColor="@color/midnight_navy"
                android:textColorHint="@color/deep_royal_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickPropertyImages"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Add photos"
                android:textAllCaps="false" />

            <TextView
                android:id="@+id/tvExistingImageSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/deep_royal_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvSelectedImageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="0 photos selected"
                android:textColor="@color/deep_royal_text"
                android:textSize="13sp" />

            <ProgressBar
                android:id="@+id/pbPropertySave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProperty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:text="Save property"
                android:textAllCaps="false" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
